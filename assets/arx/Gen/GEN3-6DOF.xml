<mujoco model="GEN3-6DOF">
  <compiler angle="radian" meshdir="meshes" autolimits="true" eulerseq="zyx"/>

  <option integrator="implicitfast" timestep="0.001" gravity="0 0 -9.81" />

  <default>
    <default class="gen3">
      <default class="visual">
        <geom type="mesh" contype="0" conaffinity="0" group="2"/>
      </default>
      <default class="collision">
        <geom type="capsule" group="3"/>
      </default>
      <joint axis="0 0 1" range="-3.1415 3.1415" damping="0.01" armature="0.01" frictionloss="0.01"/>
      <default class="joint_unlimited">
        <joint range="-6.28319 6.28319"/>
      </default>
      <default class="position">
        <position ctrlrange="-3.1415 3.1415" kp="500" kv="100" forcerange="-99 99"/>
        <default class="position_unlimited">
          <position ctrlrange="-6.2831 6.2831"/>
        </default>
        <default class="position_wrist">
          <position kp="500" kv="25" forcerange="-39 39"/>
        </default>
      </default>
    </default>
  </default>

  <asset>
    <material name="gen3_gray" rgba="0.75294 0.75294 0.75294 1"/>
    
    <mesh name="base_link" content_type="model/stl" file="base_link.STL" />
    <mesh name="shoulder_link" content_type="model/stl" file="shoulder_link.STL" />
    <mesh name="bicep_link" content_type="model/stl" file="bicep_link.STL" />
    <mesh name="forearm_link" content_type="model/stl" file="forearm_link.STL" />
    <mesh name="spherical_wrist_1_link" content_type="model/stl" file="spherical_wrist_1_link.STL" />
    <mesh name="spherical_wrist_2_link" content_type="model/stl" file="spherical_wrist_2_link.STL" />
    <mesh name="bracelet_with_vision_link" content_type="model/stl" file="bracelet_with_vision_link.STL" />
    
    <texture name="texplane" type="2d" builtin="checker" rgb1=".0 .0 .0" rgb2=".8 .8 .8" width="100" height="100" />
    <material name="matplane" reflectance="0." texture="texplane" texrepeat="1 1" texuniform="true" />
  </asset>

  <worldbody>
    <light diffuse=".5 .5 .5" pos="0 0 4" dir="0 0 -1"/>
    <geom name="ground" type="plane" pos="0 0 0" size="100 100 0.001" quat="1 0 0 0" material="matplane" condim="3" conaffinity="15" />
    <camera name="fixed" pos="0 -3.0 0.5" xyaxes="1 0 0 0 0 1" />
    <camera name="track" mode="trackcom" pos="0 -3.0 0.5" xyaxes="1 0 0 0 0 1" />
    
    <!-- 仿照UR5e的方式：固定底座，直接放置 -->
    <body name="gen3_base" pos="0 0 0" quat="1 0 0 0" childclass="gen3">
      <!-- 重要：底座的质量和惯性，从URDF复制 -->
      <inertial mass="1.697" pos="-0.000648 -0.000166 0.084487" diaginertia="0.004622 0.004495 0.002079"/>
      
      <!-- 底座几何体 -->
      <geom mesh="base_link" material="gen3_gray" class="visual"/>
      <geom mesh="base_link" class="collision" size="0.08 0.08 0.08"/>  <!-- 简化碰撞体 -->
      
      <!-- 第一个关节连接的肩部 -->
      <body name="shoulder_link" pos="0 0 0.15643" quat="-3.67321e-06 -1 0 0">
        <!-- 重要：肩部的质量 -->
        <inertial mass="1.377" pos="-2.3e-05 -0.010364 -0.07336" quat="0.707051 0.0451246 -0.0453544 0.704263" diaginertia="0.00488868 0.00457 0.00135132"/>
        
        <!-- 重要：第一个关节在这里！ -->
        <joint name="joint_1"/>
        
        <!-- 肩部几何体 -->
        <geom mesh="shoulder_link" material="gen3_gray" class="visual"/>
        <geom class="collision" size="0.06 0.06 0.08" pos="0 0 -0.04"/>
        
        <body name="bicep_link" pos="0 0.005375 -0.12838" quat="0.707105 0.707108 0 0">
          <inertial mass="1.262" pos="3.5e-05 -0.208207 -0.01889" quat="0.499531 0.50049 -0.500566 0.499411" diaginertia="0.0471882 0.046752 0.000849791"/>
          <joint name="joint_2"/>
          <geom mesh="bicep_link" material="gen3_gray" class="visual"/>
          <geom class="collision" size="0.05 0.2" pos="0 -0.2 0"/>
          
          <body name="forearm_link" pos="0 -0.41 0" quat="-3.67321e-06 1 0 0">
            <inertial mass="0.93" pos="1.8e-05 0.076168 -0.01397" quat="0.513497 0.485985 -0.486188 0.513577" diaginertia="0.00848774 0.008292 0.000604256"/>
            <joint name="joint_3"/>
            <geom mesh="forearm_link" material="gen3_gray" class="visual"/>
            <geom class="collision" size="0.038 0.19" pos="0 0.1 0"/>
            
            <body name="spherical_wrist_1_link" pos="0 0.20843 -0.006375" quat="0.707105 0.707108 0 0">
              <inertial mass="0.6781" pos="-1e-06 0.008486 -0.062937" quat="0.704382 -0.062019 0.062019 0.704382" diaginertia="0.00170753 0.001645 0.000347472"/>
              <joint name="joint_4" class="joint_unlimited"/>
              <geom mesh="spherical_wrist_1_link" material="gen3_gray" class="visual"/>
              <geom class="collision" size="0.04 0.06" pos="0 0 -0.03"/>
              
              <body name="spherical_wrist_2_link" pos="0 -0.00017505 -0.10593" quat="0.707105 -0.707108 0 0">
                <inertial mass="0.678" pos="-1e-06 0.046429 -0.008704" quat="0.5446 0.451011 -0.451011 0.5446" diaginertia="0.00174437 0.001685 0.000351632"/>
                <joint name="joint_5"/>
                <geom mesh="spherical_wrist_2_link" material="gen3_gray" class="visual"/>
                <geom class="collision" size="0.04 0.06" pos="0 0.04 0"/>
                
                <body name="bracelet_link" pos="0 0.10593 -0.00017505" quat="0.707105 0.707108 0 0">
                  <inertial mass="0.5" pos="0.000281 0.011402 -0.029798" quat="0.394358 0.596779 -0.577293 0.393789" diaginertia="0.000657336 0.000587019 0.000320645"/>
                  <joint name="joint_6" class="joint_unlimited"/>
                  <geom mesh="bracelet_with_vision_link" material="gen3_gray" class="visual"/>
                  <geom class="collision" type="cylinder" size="0.04 0.02" pos="0 0.05 0"/>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <actuator>
    <!-- 仿照UR5e的actuator配置 -->
    <position class="position_unlimited" name="joint_1" joint="joint_1"/>
    <position class="position" name="joint_2" joint="joint_2"/>
    <position class="position" name="joint_3" joint="joint_3"/>
    <position class="position_unlimited" name="joint_4" joint="joint_4"/>
    <position class="position_wrist" name="joint_5" joint="joint_5"/>
    <position class="position_unlimited" name="joint_6" joint="joint_6"/>
  </actuator>

  <keyframe>
    <key name="home"
         qpos="0 -1.57 -1.57 -1.57 0 0"
         ctrl="0 -1.57 -1.57 -1.57 0 0"/>
    <key name="zero"
         qpos="0 0 0 0 0 0"
         ctrl="0 0 0 0 0 0"/>
  </keyframe>
</mujoco>